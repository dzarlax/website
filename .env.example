# Per-machine config. Copy to .env (gitignored) and edit.
#
#   cp .env.example .env

# Path to your Obsidian vault root containing articles/ and tags/.
# In Git Bash on Windows, drive letters are mounted as /c/, /d/, etc.
# Use the Git Bash POSIX-style path (forward slashes, drive as folder).
#
# Examples:
#   macOS:    BLOG_VAULT=/Users/dzarlax/Projects/Documents/Personal/blog
#   Windows:  BLOG_VAULT=/d/Documents/Personal/blog
#             BLOG_VAULT=/d/Personal/blog
#
# If unset, scripts probe sensible defaults:
#   macOS:    $HOME/Projects/Documents/Personal/blog → fallback $HOME/Documents/Personal/blog
#   Windows:  /d/Documents/Personal/blog → /d/Personal/blog → /d/blog → C: paths
BLOG_VAULT=
